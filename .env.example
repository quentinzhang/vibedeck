# Rushdeck environment examples

# Optional: override hub root path
# PRD_HUB_ROOT=/absolute/path/to/your/hub

# Optional: editor command used by dashboard edit action
# PRD_DASHBOARD_EDITOR=code

# Optional: allow non-local dashboard API access (use carefully)
# PRD_DASHBOARD_ALLOW_REMOTE=false

# Optional: absolute path to tmux
# PRD_TMUX_BIN=/usr/local/bin/tmux
