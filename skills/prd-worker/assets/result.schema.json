{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PRD Autopilot Worker Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcome", "summary", "blockers", "validation", "files_changed", "commit", "notes"],
  "properties": {
    "outcome": {
      "type": "string",
      "enum": ["in-review", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "ok", "notes"],
        "properties": {
          "command": { "type": "string" },
          "ok": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "commit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created", "message"],
      "properties": {
        "created": { "type": "boolean" },
        "message": { "type": "string" }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
